{
  "name": "serverstick-bundle",
  "version": "2.0.0",
  "description": "Custom skills and scripts for ServerStick — Pangolin provisioning, service management, tier switching, and Hermes dashboard integration via hermes-bridge.",
  "skills": [
    {
      "id": "pangolin-provision",
      "path": "skills/pangolin-provision.md",
      "triggers": ["/provision", "provision this device", "set up tunnel"]
    },
    {
      "id": "pangolin-resource",
      "path": "skills/pangolin-resource.md",
      "triggers": ["/add-resource", "/remove-resource", "expose service", "add subdomain"]
    },
    {
      "id": "llmfit-scan",
      "path": "skills/llmfit-scan.md",
      "triggers": ["/llmfit", "what model can I run", "scan my hardware", "local AI"]
    },
    {
      "id": "install-service",
      "path": "skills/install-service.md",
      "triggers": ["/install", "install service", "add service"]
    },
    {
      "id": "hermes-webui-connector",
      "path": "skills/hermes-webui-connector.md",
      "triggers": ["/connect-webui", "link hermes to dashboard", "web ui bridge"]
    },
    {
      "id": "hermes-tier-switch",
      "path": "skills/hermes-tier-switch.md",
      "triggers": ["/tier", "switch ai", "set ai tier"]
    }
  ],
  "scripts": [
    {
      "id": "apply-tier",
      "path": "scripts/apply-tier.sh",
      "purpose": "Apply AI tier (local/byo/managed) to running Hermes",
      "called_by": ["skill:hermes-tier-switch", "bridge /api/onboard/brain"]
    },
    {
      "id": "llmfit-scan",
      "path": "scripts/llmfit-scan.sh",
      "purpose": "Detect hardware and recommend LLM model",
      "called_by": ["skill:llmfit-scan", "bridge /api/hardware/scan"]
    }
  ],
  "config_templates": [
    {
      "id": "tier.env",
      "path": "config/tier.env.template",
      "installed_to": "/etc/serverstick/tier.env",
      "written_by": "Svelte GUI after user picks tier",
      "read_by": "scripts/apply-tier.sh"
    },
    {
      "id": "nemoclaw.env",
      "path": "config/nemoclaw.env.template",
      "installed_to": "/etc/serverstick/nemoclaw.env",
      "written_by": "scripts/apply-tier.sh",
      "read_by": "nemohermes onboard"
    }
  ],
  "integration": {
    "hermes_bridge": {
      "port": "SERVERSTICK_PORT (default 18090, from /etc/serverstick/agent.env)",
      "dashboard": "Svelte build served at /",
      "api_prefix": "/api",
      "chat_proxy": "WS /ws/chat → NemoClaw :8642"
    },
    "nemoclaw": {
      "sandbox_name": "serverstick",
      "onboard_command": "nemohermes onboard --non-interactive",
      "dashboard_port": 18789,
      "api_port": 8642
    },
    "pangolin": {
      "api_url": "http://89.125.209.77:3003",
      "tunnel_endpoint": "https://pangolin.serverstick.com",
      "newt_config": "/etc/newt/newt.json"
    }
  }
}
