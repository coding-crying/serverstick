# NemoClaw / Hermes non-interactive env
# Generated by Svelte onboarding wizard from GUI choices
# Passed to: nemohermes onboard (or written to /sandbox/.hermes/.env)

# ─── Required by NemoClaw ─────────────────────────────────────────
NEMOCLAW_AGENT=hermes
NEMOCLAW_NON_INTERACTIVE=1
NEMOCLAW_ACCEPT_THIRD_PARTY_SOFTWARE=1
NEMOCLAW_SANDBOX_NAME=serverstick

# ─── Hermes dashboard (auto-forwarded by NemoClaw) ────────────────
# Set to the public URL the user will hit after provisioning
# hermes-bridge fills this in with the user's subdomain after Pangolin connects
CHAT_UI_URL=https://chat.{{device}}.serverstick.com:18789

# ─── TUI in browser tab (optional, adds terminal in dashboard) ────
NEMOCLAW_HERMES_DASHBOARD_TUI=1

# ─── Inference provider (set by tier switch) ───────────────────────
# For TIER=local:    INFERENCE_PROVIDER=local
# For TIER=byo:      INFERENCE_PROVIDER=openai
# For TIER=managed:  INFERENCE_PROVIDER=openai
INFERENCE_PROVIDER=local

# Local inference target (when INFERENCE_PROVIDER=local)
INFERENCE_LOCAL_URL=http://localhost:8081

# OpenAI-compatible (when INFERENCE_PROVIDER=openai)
# Base URL: api.openai.com | api.anthropic.com | api.groq.com/openai | api.together.xyz/openai | api.tokenrouter.com/v1
# OPENAI_API_KEY=*** OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ─── Selected model (whichever provider) ───────────────────────────
HERMES_MODEL=mistralai/Mistral-7B-Instruct-v0.3
