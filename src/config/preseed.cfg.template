# ServerStick — Preseed Configuration
# ==========================================================
# This is a TEMPLATE. The actual preseed is generated by the ISO
# build script, which replaces %%STARTER_KEY%% with the per-customer
# key. Never commit a preseed with a real key.
#
# Usage: build-iso.sh reads this template and substitutes the key.
#   sed "s/%%STARTER_KEY%%/${KEY}/" preseed.cfg.template > preseed.cfg
# ==========================================================

# ─── Localization ─────────────────────────────────────────────
d-i debian-installer/language string en
d-i debian-installer/country string US
d-i debian-installer/locale string en_US.UTF-8
d-i localechooser/translation/warn-light boolean true
d-i keyboard-configuration/xkb-keymap select us

# ─── Network ─────────────────────────────────────────────────
d-i netcfg/choose_interface select auto
d-i netcfg/disable_autoconfig boolean false
d-i netcfg/get_hostname string serverstick
d-i netcfg/get_domain string local
d-i netcfg/wireless_show_essids select manual
# Headless fallback: mDNS broadcasts serverstick.local via avahi-daemon

# ─── Mirror ───────────────────────────────────────────────────
d-i mirror/country string manual
d-i mirror/http/hostname string deb.debian.org
d-i mirror/http/directory string /debian
d-i mirror/http/proxy string
d-i mirror/suite string bookworm

# ─── Account ─────────────────────────────────────────────────
# Root account disabled — use sudo
d-i passwd/root-login boolean false
d-i passwd/make-user boolean true
d-i passwd/user-fullname string ServerStick
d-i passwd/username string serverstick
d-i passwd/user-password password serverstick
d-i passwd/user-password-again password serverstick
# NOTE: First boot forces password change. This is the initial password only.
d-i user-setup/allow-password-weak boolean true
d-i user-setup/encrypt-home boolean false

# ─── Clock ────────────────────────────────────────────────────
d-i clock-setup/utc boolean true
d-i time/zone string Etc/UTC
d-i clock-setup/ntp boolean true

# ─── Partitioning ─────────────────────────────────────────────
# Full disk, LVM, no questions asked
d-i partman-auto/method string lvm
d-i partman-auto/choose_recipe select atomic
d-i partman-lvm/device_remove_lvm boolean true
d-i partman-lvm/confirm boolean true
d-i partman-auto-lvm/guided_size string max
d-i partman/confirm boolean true
d-i partman/confirm_nooverwrite boolean true

# ─── Package Selection ────────────────────────────────────────
d-i tasksel/tasks-multiselect select ssh-server
d-i pkgsel/include string curl wget git python3 python3-pip python3-venv avahi-daemon ca-certificates jq
# Docker, Node.js, SOPS, age installed by get.serverstick.sh (not in preseed —
# we want the latest versions, and Docker requires its own repo)

d-i pkgsel/upgrade select full-upgrade
d-i pkgsel/update-policy select unattended-upgrades

# ─── GRUB ─────────────────────────────────────────────────────
d-i grub-installer/only_debian boolean true
d-i grub-installer/with_other_os boolean true
d-i grub-installer/bootdev string default

# ─── Finish ────────────────────────────────────────────────────
d-i finish-install/reboot_in_progress note
d-i debian-installer/exit/reboot boolean true

# ─── Late Command (THE PRODUCT) ────────────────────────────────────────────
# This is where ServerStick actually happens. After Debian installs,
# we download and run the bootstrap script with the preseeded starter key.
#
# Template placeholders (replaced during ISO build):
#   %%STARTER_KEY%%           — Per-customer API key (~20 credits)
#   %%PANGOLIN_NEWT_ID%%      — Newt tunnel ID (optional — omit for LAN-only)
#   %%PANGOLIN_SECRET%%        — Newt secret (optional — omit for LAN-only)
#   %%PANGOLIN_ENDPOINT%%      — Gerbil endpoint (default: gerbil.pangolin.net:50120)
#
# If Pangolin credentials are not provided, the device works on LAN only.
# Run provision-pangolin.sh later to enable remote access.
d-i preseed/late_command string \
  in-target mkdir -p /etc/serverstick/secrets /etc/serverstick/sops /var/lib/serverstick ; \
  in-target sh -c 'echo "%%STARTER_KEY%%" > /etc/serverstick/starter-key && chmod 600 /etc/serverstick/starter-key' ; \
  in-target sh -c 'echo "https://api.openai.com/v1" > /etc/serverstick/api-base && chmod 644 /etc/serverstick/api-base' ; \
  in-target sh -c 'if [ -n "%%PANGOLIN_NEWT_ID%%" ]; then echo "%%PANGOLIN_NEWT_ID%%" > /etc/serverstick/newt-id && chmod 600 /etc/serverstick/newt-id; fi' ; \
  in-target sh -c 'if [ -n "%%PANGOLIN_SECRET%%" ]; then echo "%%PANGOLIN_SECRET%%" > /etc/serverstick/newt-secret && chmod 600 /etc/serverstick/newt-secret; fi' ; \
  in-target curl -sL https://get.serverstick.sh | SERVERSTICK_STARTER_KEY=%%STARTER_KEY%% PANGOLIN_NEWT_ID=%%PANGOLIN_NEWT_ID%% PANGOLIN_SECRET=%%PANGOLIN_SECRET%% in-target bash ; \
  in-target shred -u /var/log/syslog 2>/dev/null || true