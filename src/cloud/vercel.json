{
  "framework": null,
  "rewrites": [
    { "source": "/get.sh", "destination": "/public/get.sh" },
    { "source": "/v1/models", "destination": "/api/v1/models" },
    { "source": "/v1/models/", "destination": "/api/v1/models" },
    { "source": "/v1/key-status", "destination": "/api/v1/key-status" },
    { "source": "/v1/key-status/", "destination": "/api/v1/key-status" },
    { "source": "/v1/register", "destination": "/api/v1/register" },
    { "source": "/v1/register/", "destination": "/api/v1/register" },
    { "source": "/health", "destination": "/api/health" }
  ],
  "headers": [
    {
      "source": "/get.sh",
      "headers": [
        { "key": "Content-Type", "value": "text/x-shellscript; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/v1/models",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" }
      ]
    },
    {
      "source": "/v1/key-status",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/v1/register",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}